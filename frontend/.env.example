# Production: your Render (or other) API origin — may be with or without trailing /api (app normalizes).
# Examples: https://your-api.onrender.com  OR  https://your-api.onrender.com/api
VITE_API_ROOT=/api

# Only needed for GitHub Pages-style subdirectory hosting (usually set in CI).
# VITE_BASE_PATH=/your-repo-name/

# Optional. Before this instant (ISO-8601), public event modules redirect to /levels; omit for always-on.
# VITE_PUBLIC_EVENT_MODULES_OPEN_AT=2026-05-15T08:00:00+03:00

# Supabase Auth in the admin UI (optional; same email must exist in Admin table).
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# If the API serves legacy /uploads on another host, set that origin (see DEPLOYMENT.md).
# VITE_ASSET_ORIGIN=https://your-api.onrender.com

# VITE_WHATSAPP_URL=https://wa.me/254700000000
