# =============================================================================
# Coffee & Code — environment reference (see DEPLOYMENT.md "What is already…")
#
# Where each value lives:
#   Render Web Service  → DATABASE_URL, JWT_SECRET, CORS_ORIGIN, PUBLIC_APP_URL,
#                         SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY (and optional bucket)
#   GitHub Actions      → Secrets/vars named VITE_* (build-time for Pages)
#   Local dev           → backend/.env and frontend/.env (or .env.local)
# =============================================================================

# --- Supabase (database + storage + optional admin auth) ---
# Project Settings → Database → Connection string (URI). Use port 5432 for Prisma migrate/push, or pooler 6543 + ?pgbouncer=true for some hosts.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Project Settings → API → Project URL and keys
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional: defaults to registration-uploads (must exist in Storage; see supabase/storage.sql)
# SUPABASE_STORAGE_BUCKET=registration-uploads

# --- API server (set these on Render, or in backend/.env for local) ---
JWT_SECRET=use-a-long-random-string-in-production
PORT=4000

# Comma-separated origins of sites that may call this API (no spaces). Include GitHub Pages URL.
CORS_ORIGIN=http://localhost:5173,https://YOUR_USER.github.io/YOUR_REPO

# Same as the public site URL users open (GitHub Pages, Vercel, or custom domain).
PUBLIC_APP_URL=https://YOUR_USER.github.io/YOUR_REPO

# When Supabase Storage env vars are omitted, screenshots are written under UPLOAD_DIR (dev only).
# UPLOAD_DIR=./uploads/screenshots

# --- Frontend (GitHub Actions secrets / Vercel env / frontend/.env locally) ---
# Your Render service origin; /api is added automatically if omitted (see frontend/src/lib/api.ts).
VITE_API_ROOT=https://your-service.onrender.com

# Optional: subdirectory hosting (GitHub Pages project site), e.g. /repo-name/
# VITE_BASE_PATH=/repo-name/

# Event modules (teams, Q&A, etc.) unlock in the browser after the attendee is checked in
# and opens their /status/:id page once — see DEPLOYMENT.md. (Unused legacy var:)
# VITE_PUBLIC_EVENT_MODULES_OPEN_AT=

# When using Supabase Auth for admin login in the browser (same email must exist in Admin table + Supabase user)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# If the API serves legacy /uploads paths on a different host than VITE_API_ROOT, set the API origin here.
# VITE_ASSET_ORIGIN=https://your-api.example.com

# VITE_WHATSAPP_URL=https://wa.me/254700000000
