# =============================================================================
# Coffee & Code — environment template (copy to backend/.env, frontend/.env)
# See DEPLOYMENT.md for Vercel + Supabase + API hosting.
# =============================================================================

# --- Supabase (database + storage + optional admin auth) ---
# Project Settings → Database → Connection string (URI). Use port 5432 for Prisma migrate/push, or pooler 6543 + ?pgbouncer=true for some hosts.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Project Settings → API → Project URL and keys
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional: defaults to registration-uploads (must exist in Storage; see supabase/storage.sql)
# SUPABASE_STORAGE_BUCKET=registration-uploads

# --- API server (Render, Railway, Fly, VPS, etc. — not Vercel serverless for this repo) ---
JWT_SECRET=use-a-long-random-string-in-production
PORT=4000

# Comma-separated browser origins allowed to call the API (include your Vercel URL).
CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app

# Used in badge QR targets and emails; set to your deployed frontend URL.
PUBLIC_APP_URL=https://your-app.vercel.app

# When Supabase Storage env vars are omitted, screenshots are written under UPLOAD_DIR (dev only).
# UPLOAD_DIR=./uploads/screenshots

# --- Frontend (Vite / Vercel) ---
# Production: full URL to the deployed API, ending in /api if your API is mounted at /api
VITE_API_ROOT=https://your-api.example.com/api

# Optional: subdirectory hosting (GitHub Pages style)
# VITE_BASE_PATH=/repo-name/

# Optional: lock public event modules until this ISO instant
# VITE_PUBLIC_EVENT_MODULES_OPEN_AT=2026-06-01T08:00:00+03:00

# When using Supabase Auth for admin login in the browser (same email must exist in Admin table + Supabase user)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# If the API serves legacy /uploads paths on a different host than VITE_API_ROOT, set the API origin here.
# VITE_ASSET_ORIGIN=https://your-api.example.com

# VITE_WHATSAPP_URL=https://wa.me/254700000000
