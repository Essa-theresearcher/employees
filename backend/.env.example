# Copy to backend/.env for local API. On Render, set the same keys in the service Environment.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coffee_and_code"
JWT_SECRET="replace-with-long-random-string"
PORT=4000

# Origins allowed to call the API (browser). Match your live frontend, e.g. GitHub Pages:
# CORS_ORIGIN="http://localhost:5173,https://YOUR_USER.github.io/YOUR_REPO"
CORS_ORIGIN="http://localhost:5173"
PUBLIC_APP_URL="http://localhost:5173"

UPLOAD_DIR="./uploads/screenshots"

# Supabase (same project as DATABASE_URL when using Supabase Postgres). Set on Render for Storage + admin token verify.
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# SUPABASE_STORAGE_BUCKET=registration-uploads
