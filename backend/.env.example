# Copy to backend/.env for local API. On Render, set the same keys in the service Environment.

# Supabase / production: URI from dashboard often needs ?sslmode=require on the query string.
# Direct: postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# Session pooler: user MUST be postgres.PROJECT_REF (see DEPLOYMENT.md) — not plain "postgres" on pooler host.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coffee_and_code"
JWT_SECRET="replace-with-long-random-string"
PORT=4000

# Comma-separated frontend origins (no spaces). Browser Origin has no path — https://user.github.io for GitHub Pages.
# CORS_ORIGIN="http://localhost:5173,https://YOUR_USER.github.io"
CORS_ORIGIN="http://localhost:5173"
PUBLIC_APP_URL="http://localhost:5173"

UPLOAD_DIR="./uploads/screenshots"

# Supabase (same project as DATABASE_URL when using Supabase Postgres). Set on Render for Storage + admin token verify.
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# SUPABASE_STORAGE_BUCKET=registration-uploads

# Optional: true briefly on Render so 500 JSON responses include a "detail" field (turn off after debugging).
# EXPOSE_SERVER_ERRORS=true
